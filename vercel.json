{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "cleanUrls": false,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/manifest.json", "destination": "/api/manifest" },
    { "source": "/manifest", "destination": "/api/manifest" },
    { "source": "/api/manifest.json", "destination": "/api/manifest" },

    { "source": "/stream/:type/:id.json", "destination": "/api/stream?type=:type&id=:id" },
    { "source": "/stream/:type/:id", "destination": "/api/stream?type=:type&id=:id" },
    { "source": "/api/stream/:type/:id.json", "destination": "/api/stream?type=:type&id=:id" },
    { "source": "/api/stream/:type/:id", "destination": "/api/stream?type=:type&id=:id" },

    { "source": "/direct/:source/:token/:filename(.+)", "destination": "/api/direct" },
    { "source": "/api/direct/:source/:token/:filename(.+)", "destination": "/api/direct" },

    { "source": "/health", "destination": "/api/health" }
  ],
  "functions": {
    "api/stream.js": {
      "memory": 2048,
      "maxDuration": 120
    },
    "api/direct.js": {
      "memory": 1024,
      "maxDuration": 300
    },
    "api/manifest.js": {
      "memory": 128,
      "maxDuration": 5
    },
    "api/health.js": {
      "memory": 128,
      "maxDuration": 5
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, HEAD, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type, Range" },
        { "key": "Access-Control-Expose-Headers", "value": "Content-Length, Content-Range, Accept-Ranges" }
      ]
    }
  ]
}
